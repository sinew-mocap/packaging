# Sinew mocap driver service configuration — /etc/default/sinew-driver
#
# The driver sends UDP-unicast OSC to ONE destination.  Point SINEW_DEST_IP at
# the machine that should receive the mocap stream (e.g. the host running the
# viewer or the game engine), then: systemctl restart sinew-driver
SINEW_DEST_IP=127.0.0.1
SINEW_DEST_PORT=39539

# Optional kit-specific calibration files.  If unset, the binary falls back to
# its built-in default tables.
#SINEW_HWID_FILE=/opt/org.v-sekai/sinew/0.4/share/sinew/hwid_table.ini
#SINEW_ACTIVATES_FILE=/opt/org.v-sekai/sinew/0.4/share/sinew/activates.ini
